# Copy to .env (never commit .env). Streamlit Community Cloud: use the
# dashboard "Secrets" UI instead of this file for production keys.

# SQLite used by signalhub-ble CLI and dashboard default path
# SIGNALHUB_DB=G:/path/to/signalhub.sqlite

# Optional: OpenAI for dashboard "AI narrative" tab (same vars as CLI)
# OPENAI_API_KEY=
# SIGNALHUB_OPENAI_API_KEY=
# SIGNALHUB_OPENAI_BASE_URL=https://api.openai.com/v1

# Local-only: create GitHub repo via scripts/publish_to_github.py (do not commit token)
# GITHUB_TOKEN=
